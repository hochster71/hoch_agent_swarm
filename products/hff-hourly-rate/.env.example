# =============================================================================
# HFF — Effective Hourly Rate Report — Environment variables (EXAMPLE)
# =============================================================================
# Copy to `.env` and fill in real values LOCALLY only. NEVER commit a real .env.
# In production, set these in the Vercel dashboard (Project > Settings > Env Vars).
#
# This scaffold is INERT until STRIPE_SECRET_KEY is set. All values below are
# placeholders — no real key, price, or secret is stored in this repo.
# =============================================================================

# Server-side Stripe secret. Use sk_test_... until ready to go live (sk_live_...).
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Stripe Price ID for the $9 ONE-TIME "Effective Hourly Rate Report":
STRIPE_PRICE_REPORT=price_REPLACE_ME_REPORT

# Stripe webhook signing secret (from the Stripe Dashboard webhook endpoint).
# Required for api/webhook.js to verify events and grant entitlements. Until it
# is set, the webhook is inert (returns 501 not_configured).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Public base URL, used for Stripe success/cancel redirects.
BASE_URL=http://localhost:3000

# --- Optional but STRONGLY recommended before taking real money: Vercel KV ---
# When BOTH are set, lib/store.js uses Vercel KV so entitlements survive across
# serverless invocations and deploys. If unset, it falls back to an in-memory
# store, which is fine for local/dev and tests but is NOT durable in production:
# a cold start would lose a buyer's unlock.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Optional: local engine testing without payments ---
# Set to 1 to let api/generate-report.js run the engine with NO Stripe wired.
# NOT real payment — for founder/local testing only. Leave UNSET in production.
# HOURLYRATE_DEV_UNLOCK=1
