# =============================================================================
# CyberQRG (Hoch Cyber Factory / HCF) — Environment variables (EXAMPLE)
# =============================================================================
# Copy this file to `.env` and fill in real values LOCALLY only.
# NEVER commit a real `.env` — it is git-ignored (see .gitignore).
# In production, set these in the Vercel dashboard
# (Project > Settings > Environment Variables), NOT in a committed file.
#
# This scaffold is INERT until STRIPE_SECRET_KEY is set. All values below are
# placeholders — NO real keys are included.
# =============================================================================

# --- Stripe secret key -------------------------------------------------------
# Server-side secret. Use a TEST key (sk_test_...) until ready to go live.
# Going live requires swapping in a live key (sk_live_...).
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# --- Stripe Price ID ---------------------------------------------------------
# Create a $9 one-time Price ("CyberQRG Safe-Scan Pack — 100 scans") in the
# Stripe dashboard, then paste its ID here. Looks like price_xxxxxxxxxxxx.
STRIPE_PRICE_SCANPACK=price_REPLACE_ME_SCANPACK

# --- Public base URL ---------------------------------------------------------
# Used to build Stripe success/cancel redirect URLs. In production set this to
# your deployed domain, e.g. https://cyberqrg.hoch.app
BASE_URL=http://localhost:3000
