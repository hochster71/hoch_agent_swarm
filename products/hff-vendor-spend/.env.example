# HFF — Vendor Spend Rollup — environment template.
#
# PLACEHOLDERS ONLY. Never commit a real key. Set the real values in the Vercel
# project's Environment Variables UI (or via `vercel env add`), which is a
# FOUNDER action — the build loop never handles secrets.

# Stripe secret key (live: sk_live_..., test: sk_test_...).
# Absent -> /api/create-checkout-session and /api/webhook return 501 (inert).
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Price ID for the one-time $9 report unlock. Create it in the Stripe dashboard.
STRIPE_PRICE_REPORT=price_REPLACE_ME

# Webhook signing secret from the Stripe endpoint (whsec_...).
# Absent -> /api/webhook returns 501. Wrong -> 400 (fails closed, by design).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Public base URL used to build Stripe success/cancel URLs.
BASE_URL=https://REPLACE_ME.vercel.app

# OPTIONAL — durable entitlement store. Without BOTH of these the store falls
# back to an in-memory Map, which does NOT survive serverless cold starts.
# For real buyers, set these.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# LOCAL DEVELOPMENT ONLY. Set to 1 to unlock the paid report without payment.
# NEVER set this in a production environment.
VENDORSPEND_DEV_UNLOCK=
