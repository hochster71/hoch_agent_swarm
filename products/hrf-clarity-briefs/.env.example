# =============================================================================
# HRF — Clarity Briefs — Environment variables (EXAMPLE / TEMPLATE)
# =============================================================================
# Copy to `.env` and fill in real values LOCALLY only. NEVER commit a real .env.
# In production, set these in the Vercel dashboard (Project > Settings > Env Vars).
#
# This scaffold is INERT until STRIPE_SECRET_KEY is set. All values below are
# placeholders — no real keys are included.
# =============================================================================

# Server-side Stripe secret. Use sk_test_... until ready to go live (sk_live_...).
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Stripe webhook signing secret (whsec_...). Used by api/webhook.js to verify
# every event. Get it from the Stripe dashboard when you add the webhook
# endpoint (…/api/webhook), or from `stripe listen` for local testing.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Path to the file-backed entitlement store that BOTH api/webhook.js writes and
# the Python engine (engine/entitlement.py, via api/generate.py) reads. On a host
# with a persistent writable filesystem this can be a data dir; on Vercel point
# it at a mounted/persistent volume (serverless /tmp is per-invocation only).
HRF_ENTITLEMENTS_PATH=entitlements.json

# Stripe Price IDs (create these in the Stripe dashboard, then paste the IDs).
# $5/mo recurring subscription:
STRIPE_PRICE_MONTHLY=price_REPLACE_ME_MONTHLY
# $2 one-time single brief:
STRIPE_PRICE_BRIEF=price_REPLACE_ME_BRIEF

# Public base URL, used for Stripe success/cancel redirects.
BASE_URL=http://localhost:3000
