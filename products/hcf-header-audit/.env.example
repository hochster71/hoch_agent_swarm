# HCF — Email Header Audit — environment template.
# PLACEHOLDERS ONLY. Never commit real keys. The founder sets these in Vercel.

# Stripe secret key (live or test). Without it every payment path returns 501.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Stripe Price ID for the $5 one-time audit unlock.
STRIPE_PRICE_AUDIT=price_REPLACE_ME

# Stripe webhook signing secret (from the endpoint you create in the dashboard).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Public base URL of the deployment (used for Checkout success/cancel URLs).
BASE_URL=https://REPLACE_ME.vercel.app

# OPTIONAL — Vercel KV. If unset, the entitlement store falls back to in-memory
# (fine for local/tests, NOT durable in serverless production).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# LOCAL DEV ONLY — set to 1 to bypass the paywall while testing. NOT payment.
# HEADER_DEV_UNLOCK=1
