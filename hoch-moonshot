freeze_writers() {
  say "FREEZING VOLATILE WRITERS"

  if [ -f logs/has_goal_runner_daemon.pid ]; then
    kill "$(cat logs/has_goal_runner_daemon.pid)" 2>/dev/null || true
  fi

  if [ -f logs/has_telemetry_watchdog.pid ]; then
    kill "$(cat logs/has_telemetry_watchdog.pid)" 2>/dev/null || true
  fi

  pkill -f "has_goal_runner_daemon.sh" 2>/dev/null || true
  pkill -f "has_goal_e2e_runner.sh" 2>/dev/null || true
  pkill -f "has_telemetry_watchdog.sh" 2>/dev/null || true

  ps aux | grep -E "has_goal_runner_daemon|has_goal_e2e_runner|has_telemetry_watchdog" | grep -v grep || true
}

audit_state() {
