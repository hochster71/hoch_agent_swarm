<script>
const $ = id => document.getElementById(id);
const fmtAge = s => s == null ? "--" : `${Math.round(Number(s))}s`;

function setConsole(lines){
  $("console").textContent = lines.join("\n");
}

function card(title, body, status="ACTIVE"){
  return `<div class="card"><h3>${title}</h3><p>${body}</p><span class="badge">${status}</span></div>`;
}

async function load(){
  const lines = [];
  try{
    const res = await fetch("/api/pert/data", { cache:"no-store" });
    const data = await res.json();
    const metrics = data.metrics || {};
    const pct = metrics.percent_goal_complete ?? metrics.goal_completion ?? 0;
    $("goalPct").textContent = `${pct}%`;
    $("goalBar").style.width = `${Math.max(4, Math.min(100, Number(pct)||0))}%`;
    $("pill-goal").textContent = `GOAL ${pct}%`;
    $("confidence").textContent = metrics.confidence_level || metrics.confidence || "--";
    $("expectedTime").textContent = metrics.expected_time || metrics.projected_completion || "--";

    const src = data.freshness_authority?.reconciled_sources || {};
    const freshKeys = Object.keys(src);
    const bad = freshKeys.filter(k => src[k]?.computed_state !== "FRESH");
    $("pill-telemetry").textContent = bad.length ? `STALE ${bad.length}` : "TELEMETRY FRESH";
    $("pill-blockers").textContent = bad.length ? `BLOCKERS ${bad.length}` : "BLOCKERS 0";
    $("pill-updated").textContent = new Date().toLocaleTimeString();

    $("freshness").innerHTML = freshKeys.slice(0,10).map(k => {
      const s = src[k] || {};
      const state = s.computed_state || "UNKNOWN";
      return `<div class="step"><div class="dot"></div><b>${k}</b><span>${state} age=${fmtAge(s.freshness_age_seconds)}</span></div>`;
    }).join("") || `<div class="step"><div class="dot"></div><b>No freshness authority</b><span>missing data</span></div>`;

    const agents = [
      ["PERT Analysis Agent","Critical path, estimates, confidence, time-to-complete"],
      ["Live Stale Agent","Detects stale telemetry and stale UI truth"],
      ["QA Gate Agent","Runs smoke, browser, guardrails, anti-fake checks"],
      ["Evidence Agent","Writes local audit/evidence bundles"],
      ["Revenue Agent","Tracks HASF monetization readiness"],
      ["Release Hygiene Agent","Tracks dirty tree, commits, blocked gates"]
    ];
    $("agents").innerHTML = agents.map((a,i)=>`<div class="step"><div class="dot"></div><b>${a[0]}</b><span>${a[1]}</span></div>`).join("");

    const pods = data.hoch_pods_runtime_state?.pods || data.pods || data.agents || [];
    const fallback = [
      ["Mission Commander","Coordinates GOAL, approvals, evidence"],
      ["Runtime Truth Pod","Telemetry, freshness, stale state"],
      ["UI Theater Pod","HOCH PODS liftoff visual control plane"],
      ["QA Pod","Tests, guardrails, browser verification"],
      ["Revenue Pod","HASF monetization package"],
      ["Release Pod","Commit hygiene and promotion readiness"]
    ];
    const rendered = Array.isArray(pods) && pods.length
      ? pods.slice(0,12).map(p => card(p.name || p.id || "HOCH Pod", p.summary || p.role || p.status || "Live pod state", p.state || p.status || "ACTIVE")).join("")
      : fallback.map(p => card(p[0],p[1],"SPIN-UP")).join("");
    $("podGrid").innerHTML = rendered;

    lines.push("MOONSHOT_UI: ONLINE");
    lines.push(`GOAL: ${pct}%`);
    lines.push(`FRESHNESS_SOURCES: ${freshKeys.length}`);
    lines.push(`STALE_OR_BAD: ${bad.length}`);
    lines.push("APPROVAL_GATES: Stripe, deployment, public exposure, destructive actions, tag promotion");
  }catch(e){
    setConsole(["MOONSHOT_UI: DEGRADED", String(e)]);
  }
  if(lines.length) setConsole(lines);
}
load();
setInterval(load, 10000);
</script>
