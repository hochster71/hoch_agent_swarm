    echo "# HOCH PODS Moonshot Audit"
    echo
    echo "- Timestamp UTC: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "- Branch: $(git branch --show-current)"
    echo "- Commit: $(git rev-parse --short HEAD)"
    echo
    echo "## North Star"
    echo
    echo "HAS = live autonomous command/control layer for agents, QA gates, runtime truth, approvals, telemetry, evidence, stale detection, PERT, and operator alerts."
    echo
    echo "HASF = revenue-producing Hoch Application Software Factory."
    echo
    echo "## Recent Commits"
    git log --oneline -8
    echo
    echo "## Git Status"
    git status --short
    echo
    echo "## Current Blocker Triage"
    if [ -x scripts/has_goal_blocker_triage.sh ]; then
      bash scripts/has_goal_blocker_triage.sh || true
    else
      echo "MISSING: scripts/has_goal_blocker_triage.sh"
    fi
    echo
    echo "## Live API Snapshot"
    curl -sS http://127.0.0.1:8765/api/pert/data | python3 -m json.tool | head -240 || true
