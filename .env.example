# Hoch Agent Swarm 24/7 Reliability Environment Configuration

# Core Deployment Environment
HOCH_ENV=local
HOCH_MODE=hybrid-ha-lite
HOCH_BUDGET_MAX_MONTHLY=100

# Concurrency & Workload Ceiling Policies
HOCH_REGISTERED_AGENTS=300
HOCH_MAX_ACTIVE_AGENTS=20
HOCH_MAX_LLM_CONCURRENT=3
HOCH_MAX_BROWSER_SESSIONS=2
HOCH_MAX_CODE_WORKERS=4
HOCH_MAX_QA_WORKERS=4

# Persistent Backends
HOCH_QUEUE_BACKEND=redis
HOCH_DB_BACKEND=sqlite

# Network & High Availability
HOCH_CLOUDFLARE_TUNNEL_ENABLED=false
HOCH_FAILOVER_ENABLED=true
HOCH_BACKUP_ENABLED=true

# Model Routing Configuration
HOCH_MODEL_GATEWAY=local

# Security & Credentials (Do not check secrets into source control)
# DROGON_SERVER_URL="https://drogon.tv/w/..."
# DROGON_USERNAME="michaelhoch"
# DROGON_PASSWORD="..."
