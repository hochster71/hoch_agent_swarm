FROM nginx:alpine

LABEL org.opencontainers.image.title="Hoch Agent Swarm UI" \
      org.opencontainers.image.description="Nginx Static Frontend for Hoch Agent Swarm" \
      org.opencontainers.image.version="0.1.0" \
      org.opencontainers.image.source="https://github.com/crewAIInc/crewAI" \
      org.opencontainers.image.created="2026-06-29T17:33:53Z"

COPY frontend/dist /usr/share/nginx/html
COPY docker/nginx/nginx.conf /etc/nginx/nginx.conf

# Give nginx user ownership of the static html files
RUN chown -R nginx:nginx /usr/share/nginx/html

EXPOSE 8080

USER nginx

CMD ["nginx", "-g", "daemon off;"]
