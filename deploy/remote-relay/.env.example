# HOCH Agent Swarm / Prompt Brain Remote Relay Configuration
# Copy this to .env and configure secrets. DO NOT commit actual secrets.

# Port mappings
HAS_BACKEND_PORT=8000
RELAY_API_PORT=8010
COMMAND_CENTER_PATH=/prototype/prompt-brain

# Authorization Secrets
RELAY_AUTH_TOKEN=change-me-to-a-secure-token-in-production
CLOUDFLARE_TUNNEL_TOKEN=change-me-to-your-cloudflare-tunnel-token

# Hosting Setup
PUBLIC_HOSTNAME=example.yourdomain.com
EVIDENCE_DATA_DIR=/data/runtime
BACKUP_DIR=/data/backups

# Logging & Simulation Settings
LOG_LEVEL=INFO
ALLOW_SIMULATION_FALLBACK=true
