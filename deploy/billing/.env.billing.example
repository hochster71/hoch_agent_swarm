# HASF billing environment — EXAMPLE (no real values). Copy relevant lines to .env.
# Test mode is the default and needs only the sk_test_/pk_test_ keys already set.

# --- TEST MODE (default; safe, no real charges) ---
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx        # from `stripe listen` or a test webhook endpoint

# --- GO LIVE (founder throws the switch; see docs/billing/GO_LIVE_CHECKLIST.md) ---
# Requires BOTH a live key AND the explicit switch below. Either one alone stays test-locked.
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_live_xxx   # from the LIVE webhook endpoint
# HASF_BILLING_LIVE=1                     # <-- the live switch; omit/0 to stay in test
