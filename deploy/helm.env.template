# HELM provider credentials — TEMPLATE ONLY (safe to commit; contains NO secrets).
#
# To enable provider dispatch:
#   1. cp deploy/helm.env.template ~/.helm/helm.env      (outside the repo)
#   2. chmod 600 ~/.helm/helm.env
#   3. paste your real keys into ~/.helm/helm.env  (YOUR action; never through Claude)
#   4. start the HELM server with the env sourced:  set -a; . ~/.helm/helm.env; set +a
#
# ~/.helm/helm.env is founder-controlled and MUST NOT be committed (it is gitignored).
# Claude never reads, stores, or echoes these values — only presence is ever reported.

OPENAI_API_KEY=            # frontier · orchestrator (gpt-5.6)
ANTHROPIC_API_KEY=         # frontier · builder (claude)
XAI_API_KEY=               # frontier · auditor (grok-4.5)
GEMINI_API_KEY=            # frontier · optional (gemini)
HELM_LOCAL_MODEL_URL=      # local · Ollama / LM Studio endpoint (e.g. http://localhost:11434)
