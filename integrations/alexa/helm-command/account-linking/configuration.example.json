{
  "accountLinkingRequest": {
    "type": "AUTH_CODE",
    "authorizationUrl": "https://auth.helm-gateway.local/oauth/authorize",
    "accessTokenUrl": "https://auth.helm-gateway.local/oauth/token",
    "clientId": "alexa-helm-client-id",
    "clientSecret": "amzn1.oa2-client-secret.placeholder",
    "scopes": [
      "voice:read",
      "voice:write"
    ],
    "accessTokenScheme": "HTTP_BASIC",
    "defaultTokenExpirationInSeconds": 3600
  }
}
