# =============================================================================
# Hoch Storybook Factory (HSF) — Environment variables (EXAMPLE / TEMPLATE)
# =============================================================================
# Copy this file to `.env` and fill in real values LOCALLY only.
# NEVER commit a real `.env` — it is git-ignored (see .gitignore).
# In production, set these in the Vercel dashboard (Project > Settings >
# Environment Variables), NOT in a committed file.
#
# This scaffold is INERT until STRIPE_SECRET_KEY is set. All values below are
# placeholders — no real keys are included.
# =============================================================================

# --- Stripe secret key -------------------------------------------------------
# Server-side secret. Use a TEST key (sk_test_...) until you are ready to go
# live. Going live requires the founder to swap in a live key (sk_live_...).
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# --- Stripe webhook signing secret -------------------------------------------
# Given to you by Stripe when you register the webhook endpoint (whsec_...).
# The webhook handler rejects any event that doesn't verify against this.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- Stripe Price IDs --------------------------------------------------------
# Create these Prices in the Stripe dashboard (see README), then paste their
# IDs here. They look like price_xxxxxxxxxxxxxxxx.
#
# One-time $19 single-story export:
STRIPE_PRICE_ONESTORY=price_REPLACE_ME_ONESTORY
# Recurring $12/mo creators subscription:
STRIPE_PRICE_CREATORS=price_REPLACE_ME_CREATORS

# --- Public base URL ---------------------------------------------------------
# Used to build Stripe success/cancel redirect URLs. In production set this to
# your deployed domain, e.g. https://storybook.hoch.app
BASE_URL=http://localhost:3000
