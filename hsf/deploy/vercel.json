{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/create-checkout-session",
      "destination": "/api/create-checkout-session"
    },
    {
      "source": "/api/save-story",
      "destination": "/api/save-story"
    },
    {
      "source": "/api/download",
      "destination": "/api/download"
    },
    {
      "source": "/api/webhook",
      "destination": "/api/webhook"
    },
    {
      "source": "/api/entitlement",
      "destination": "/api/entitlement"
    },
    {
      "source": "/api/auth/request-link",
      "destination": "/api/auth/request-link"
    },
    {
      "source": "/api/auth/verify",
      "destination": "/api/auth/verify"
    },
    {
      "source": "/api/export",
      "destination": "/api/export"
    },
    {
      "source": "/api/share",
      "destination": "/api/share"
    },
    {
      "source": "/api/morph",
      "destination": "/api/morph"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}