    "qa:runtime-full": "npm run qa:ui-contract && npm run qa:readiness && npm run qa:autonomy-budget && npm run qa:e2e-runtime && npm run e2e:full-page-swarm-audit && npm run e2e:capability-enforcement && npm run e2e:reduced-motion-swarm && npm run e2e:release-signing-policy && npm run e2e:release-channel-governance && npm run e2e:operator-governance && npm run e2e:candidate-release-packet && npm run e2e:formal-release-preview && npm run e2e:formal-release-approval && npm run e2e:formal-release-seal-dry-run && npm run e2e:release-seal-attestation && npm run e2e:device-registry-topology && npm run e2e:device-service-registry && npm run e2e:capability-routing"
  },
