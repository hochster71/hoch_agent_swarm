{
  "name": "hoch-agent-swarm",
  "version": "0.1.6-ERROR-BUDGET-AWARE-AUTONOMY",
  "private": true,
  "scripts": {
    "baseline:scan-static": "grep -RInE \"mock|fixture|demo|fake|placeholder|sample|seed|Math\\.random|Date\\.now|health: 100|status: ['\\\"]healthy|sync: ['\\\"]ok|latency: ['\\\"]1\\.2ms\" frontend/src backend/main.py || true",
    "baseline:validate-api": "python3 scripts/verify_realtime_integrity.py",
    "baseline:validate-audit": "python3 scripts/verify_baseline_lock.py",
    "baseline:evidence": "npx tsx scripts/generate-baseline-evidence.ts",
    "baseline:evaluate": "npx tsx scripts/baseline/ci-baseline-gate.ts",
    "baseline:capture-digests": "npx tsx scripts/baseline/capture-docker-digests.ts",
    "baseline:checksum": "npx tsx scripts/baseline/checksum-evidence-pack.ts",
    "baseline:hardening": "npm run baseline:scan-static && npm run baseline:validate-api && npm run baseline:validate-audit && npm run baseline:capture-digests && npm run baseline:evidence && npm run baseline:checksum && npm run baseline:evaluate",
    "supply:sbom": "npx tsx scripts/supply-chain/generate-sbom.ts",
    "supply:provenance": "npx tsx scripts/supply-chain/generate-provenance.ts",
    "supply:manifest": "npx tsx scripts/supply-chain/generate-release-manifest.ts",
    "supply:sign": "npx tsx scripts/supply-chain/sign-release-artifacts.ts",
    "supply:verify": "npx tsx scripts/supply-chain/verify-release-artifacts.ts",
    "supply:release": "npm run baseline:hardening && npm run supply:sbom && npm run supply:provenance && npm run supply:manifest && npm run supply:verify && npm run supply:sign",
    "test": "npx tsx scripts/baseline/verify-stale-green-regression.ts",
    "qa:audit-localhost": "npx tsx scripts/qa/audit-localhost-8000.ts",
    "qa:validate-evidence": "npx tsx scripts/qa/verify-hochster-runtime-evidence.ts",
    "qa:readiness-score": "npx tsx scripts/qa/generate-readiness-score.ts",
    "qa:north-star": "npx tsx scripts/qa/generate-north-star-report.ts",
    "qa:remediation-safety": "npx tsx scripts/qa/test-remediation-safety.ts",
    "qa:autonomy-budget": "npx tsx scripts/qa/test-autonomy-budget.ts",
    "ci:validate": "python3 scripts/qa/run-ci-pipeline.py",
    "qa:nav-contract": "npx tsx scripts/qa/test-nav-contract.ts",
    "qa:nav-live": "npx tsx scripts/qa/test-nav-live-contract.ts",
    "qa:nav": "npm run qa:nav-contract && npm run qa:nav-live",
    "qa:readiness": "npm run qa:audit-localhost && npm run qa:validate-evidence && npm run qa:readiness-score && npm run qa:north-star",
    "build:tailwind": "npx @tailwindcss/cli -i ./frontend/src/styles/tailwind.css -o ./frontend/dist/tailwind.css --minify",
    "qa:no-tailwind-cdn": "npx tsx scripts/qa/test-no-tailwind-cdn.ts",
    "build": "npm run build:tailwind",
    "qa:view-contract": "npx tsx scripts/qa/test-view-content-contract.ts",
    "qa:ui-contract": "npm run qa:no-tailwind-cdn && npm run qa:nav && npm run qa:view-contract && npm run qa:frontend-entrypoint && npm run qa:comic-swarm && npm run qa:global-swarm-animation && npm run qa:topology-agent-overlay && npm run qa:topology-animation-quality",
    "qa:frontend-entrypoint": "npx tsx scripts/qa/test-frontend-entrypoint-contract.ts",
    "qa:comic-swarm": "npx tsx scripts/qa/test-kimi-style-comic-swarm-contract.ts",
    "qa:global-swarm-animation": "npx tsx scripts/qa/test-global-swarm-animation-contract.ts",
    "qa:topology-agent-overlay": "npx tsx scripts/qa/test-topology-agent-overlay-contract.ts",
    "qa:topology-animation-quality": "npx tsx scripts/qa/test-topology-animation-quality.ts",
    "e2e:antigravity": "npx playwright test tests/e2e/antigravity-runtime.spec.ts",
    "e2e:global-swarm-animation": "npx playwright test tests/e2e/global-swarm-animation-runtime.spec.ts",
    "e2e:topology-agent-overlay": "npx playwright test tests/e2e/topology-agent-overlay.spec.ts",
    "qa:e2e-runtime": "npm run e2e:antigravity && npm run e2e:global-swarm-animation && npm run e2e:topology-agent-overlay",
    "qa:runtime-full": "npm run qa:ui-contract && npm run qa:readiness && npm run qa:autonomy-budget && npm run qa:e2e-runtime"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
