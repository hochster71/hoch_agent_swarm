{
  "_meta": {
    "schema": "hoch-asset-trust-v1",
    "created": "2026-06-26",
    "version": "1.0.0",
    "doctrine": "Zero-trust within cluster. Each node authenticated per-request. No implicit trust.",
    "pert_ref": "P3",
    "status": "ACTIVE"
  },
  "trust_tiers": {
    "ALPHA": {
      "description": "Control Plane — highest privilege. Hosts API, governance DB, orchestrator. All agent approvals go through ALPHA.",
      "can_approve_agents": true,
      "can_write_governance_db": true,
      "can_route_to_all_tiers": true,
      "can_receive_from": ["ALPHA", "BETA", "GAMMA", "DELTA"],
      "can_initiate_to": ["ALPHA", "BETA", "GAMMA", "DELTA"]
    },
    "BETA": {
      "description": "Edge Worker — compute tasks, file processing, API calls. Cannot approve agents or write governance DB.",
      "can_approve_agents": false,
      "can_write_governance_db": false,
      "can_route_to_all_tiers": false,
      "can_receive_from": ["ALPHA"],
      "can_initiate_to": ["ALPHA"]
    },
    "GAMMA": {
      "description": "Inference Node — GPU/ML tasks only. Isolated from governance DB. Read-only access to approved model artifacts.",
      "can_approve_agents": false,
      "can_write_governance_db": false,
      "can_route_to_all_tiers": false,
      "can_receive_from": ["ALPHA"],
      "can_initiate_to": ["ALPHA"],
      "isolation_note": "GAMMA nodes must not be routed financial, PII, or governance payloads without explicit ALPHA override."
    },
    "DELTA": {
      "description": "Monitor / Console — read-only visibility. Cannot execute agents or write any swarm state.",
      "can_approve_agents": false,
      "can_write_governance_db": false,
      "can_route_to_all_tiers": false,
      "can_receive_from": ["ALPHA"],
      "can_initiate_to": [],
      "read_only": true
    }
  },
