{
  "schema": "helm-voice-agent-tools-v1",
  "persona_prompt_path": "docs/prompts/helm_voice_executive_commander.md",
  "architecture_path": "docs/architecture/HELM_VOICE_EXECUTIVE_INTERFACE.md",
  "base_url_note": "Point tools at the HELM LIVE API origin (same host that serves /api/v1/helm/*). Never invent metrics when a tool returns UNKNOWN or fails.",
  "discovery_endpoint": "/api/v1/helm/voice/tools",
  "endpoints": {
    "policy": "GET /api/v1/helm/voice/policy",
    "commands": "GET /api/v1/helm/voice/commands",
    "brief": "GET /api/v1/helm/voice/brief",
    "command": "POST /api/v1/helm/voice/command",
    "command_get": "GET /api/v1/helm/voice/command?command=executive_brief",
    "sanitize": "POST /api/v1/helm/voice/sanitize",
    "health": "GET /api/v1/helm/voice/health"
  },
  "doctrine": [
    "no_fake_green",
    "unknown_is_unknown",
    "stale_is_not_live",
    "doorstep_founder_only",
    "voice_is_interface_not_intelligence"
  ]
}
