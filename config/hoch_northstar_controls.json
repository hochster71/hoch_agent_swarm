        { "id": "ZTA-001",         "name": "Zero Trust Auth between Nodes", "status": "PENDING", "pert_ref": "P3" },
        { "id": "CLUSTER-001",     "name": "Worker Profile Enforcement", "status": "PENDING", "pert_ref": "P8" }
      ]
    },
