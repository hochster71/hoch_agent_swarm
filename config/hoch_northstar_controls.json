{
  "_meta": {
    "schema": "hoch-northstar-controls-v1",
    "created": "2026-06-26",
    "version": "1.0.0",
    "sealed": false,
    "seal_requires": "operator approval + evidence artifacts complete"
  },
  "northstar_statement": "Build a local-first, ephemeral, cybersecurity-hardened AI swarm cluster that can execute life, work, cyber, research, and humanity tasks while preserving operator control, evidence, approval gates, and full auditability.",
  "principles": [
    { "id": "NS-01", "name": "Local-First", "description": "Swarm operates primarily on local hardware; cloud is opt-in, not default." },
    { "id": "NS-02", "name": "Ephemeral Execution", "description": "All agent workers are disposable; no persistent state in execution context." },
    { "id": "NS-03", "name": "Operator Control", "description": "Every HIGH-risk operation requires human operator approval before execution." },
    { "id": "NS-04", "name": "Full Auditability", "description": "Every action is logged, hash-stamped, and traceable to a specific agent and run." },
    { "id": "NS-05", "name": "Evidence-First", "description": "No control is considered active unless backed by a verifiable evidence artifact." },
    { "id": "NS-06", "name": "Cybersecurity-Hardened", "description": "Attack surface is minimized: ports, credentials, and skills are gated by policy." },
    { "id": "NS-07", "name": "Zero Trust within Cluster", "description": "Each node authenticates per-request; no implicit trust between cluster members." }
  ],
  "control_domains": [
    {
      "domain": "EPHEMERAL",
      "controls": [
        { "id": "EPHEMERAL-001", "name": "Worker Disposability", "status": "PENDING", "pert_ref": "P1" },
        { "id": "EPHEMERAL-002", "name": "No Credential Persistence", "status": "PENDING", "pert_ref": "P1" }
      ]
    },
    {
