# Apple Calendar CalDAV adapter — example environment.
# Copy to `.env` and fill in locally. NEVER commit a real password.
# Prefer the macOS Keychain over env for the password (see README.md).

APPLE_CALDAV_USERNAME=hochster_71@mac.com
# Leave BLANK here. Provide via Keychain, or export at runtime only.
APPLE_CALDAV_PASSWORD=
APPLE_CALDAV_HOST=https://caldav.icloud.com

# read_only (default) | read_write
# Writes are rejected unless this is exactly `read_write` AND approval is present.
APPLE_CALENDAR_MODE=read_only
